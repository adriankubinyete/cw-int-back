// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  ERROR
}

enum ErpType {
  IXCSOFT
  SGP
  HUBSOFT
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workflows    Workflow[]
  integrations Integration[]
}

model Workflow {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  graph       Json
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  executionLogs ExecutionLog[]

  @@index([userId])
}

model ExecutionLog {
  id           String          @id @default(uuid())
  workflowId   String
  status       ExecutionStatus
  startedAt    DateTime        @default(now())
  finishedAt   DateTime?
  inputPayload Json
  steps        Json
  errorMessage String?
  contactPhone String?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model Integration {
  id         String    @id @default(uuid())
  userId     String
  erpType    ErpType
  name       String
  authConfig String    // JSON criptografado — url, token e demais campos de autenticação
  erpConfig  String    @default("{}") // JSON criptografado — configurações específicas do ERP
  isActive   Boolean   @default(false)
  testedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, erpType])
}