// prisma/schema.prisma
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  ERROR
}

enum IntegrationType {
  IXCSOFT
  SGP
  HUBSOFT
  CHATWOOT
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workflows    Workflow[]
  integrations Integration[]
}

model Workflow {
  id                    String   @id @default(uuid())
  userId                String
  name                  String
  description           String?
  graph                 Json
  isActive              Boolean  @default(false)
  chatwootIntegrationId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatwootIntegration Integration?   @relation("WorkflowChatwoot", fields: [chatwootIntegrationId], references: [id], onDelete: SetNull)
  executionLogs       ExecutionLog[]

  @@index([userId])
  @@index([chatwootIntegrationId])
}

model ExecutionLog {
  id           String          @id @default(uuid())
  workflowId   String
  status       ExecutionStatus
  startedAt    DateTime        @default(now())
  finishedAt   DateTime?
  inputPayload Json
  steps        Json
  errorMessage String?
  contactPhone String?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model Integration {
  id              String          @id @default(uuid())
  userId          String
  integrationType IntegrationType
  name            String
  authConfig      String          // JSON criptografado — url, token, etc
  erpConfig       String          @default("{}") // JSON criptografado — configs específicas
  isActive        Boolean         @default(false)
  testedAt        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflows Workflow[] @relation("WorkflowChatwoot")

  @@index([userId])
  @@index([userId, integrationType])
}