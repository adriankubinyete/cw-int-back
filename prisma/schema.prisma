datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ExecutionStatus {
  RUNNING
  WAITING_INPUT
  SUCCESS
  ERROR
  TIMED_OUT
  OUTDATED
}

enum IntegrationType {
  IXCSOFT
  SGP
  HUBSOFT
  CHATWOOT
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workflows    Workflow[]
  integrations Integration[]
}

model Workflow {
  id                    String   @id @default(uuid())
  userId                String
  name                  String
  description           String?
  graph                 Json
  isActive              Boolean  @default(false)
  chatwootIntegrationId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatwootIntegration Integration? @relation("WorkflowChatwoot", fields: [chatwootIntegrationId], references: [id], onDelete: SetNull)
  executions          Execution[]

  @@index([userId])
  @@index([chatwootIntegrationId])
}

model Execution {
  id              String          @id @default(uuid())
  workflowId      String
  status          ExecutionStatus
  startedAt       DateTime        @default(now())
  finishedAt      DateTime?
  lastInteraction DateTime?
  timeoutMinutes  Int             @default(10)
  inputPayload    Json
  steps           Json
  errorMessage    String?
  contactPhone    String?
  conversationKey String?
  resumeNodeId    String?
  waitingVariable String?
  snapshot        Json?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([conversationKey, status])
}

model Integration {
  id              String          @id @default(uuid())
  userId          String
  integrationType IntegrationType
  name            String
  authConfig      String
  erpConfig       String          @default("{}")
  isActive        Boolean         @default(false)
  testedAt        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflows Workflow[] @relation("WorkflowChatwoot")

  @@index([userId])
  @@index([userId, integrationType])
}